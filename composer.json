{
  "name": "siap-loket/puskesmas",
  "description": "Sistem Informasi Antrian Pasien (SIAP) Puskesmas",
  "type": "project",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit tests/ --colors=always",
    "test-unit": "vendor/bin/phpunit tests/unit/ --colors=always",
    "test-integration": "vendor/bin/phpunit tests/integration/ --colors=always"
  }
}
